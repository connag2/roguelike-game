{
  "name": "roguelike-game",
  "version": "0.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.moonhs.roguelike",
    "productName": "RoguelikeTactics",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "portable"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ]
  },
  "dependencies": {
    "firebase": "^11.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
  
}
